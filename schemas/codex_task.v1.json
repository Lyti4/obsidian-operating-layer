{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex_task.v1",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "mode",
    "repo",
    "objective",
    "scope",
    "verification",
    "outputs"
  ],
  "properties": {
    "schema": {
      "const": "codex_task.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "mode": {
      "enum": [
        "implementation",
        "review",
        "audit",
        "plan-review"
      ]
    },
    "repo": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object"
    },
    "verification": {
      "type": "object"
    },
    "outputs": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
